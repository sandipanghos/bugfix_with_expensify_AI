{
  "info": {
    "name": "GitHub Issue Notifier",
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "All API endpoints for the GitHub Issue Notifier backend."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "GET /health/ready",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Config",
      "item": [
        {
          "name": "GET /api/config",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/config"
          }
        },
        {
          "name": "PUT /api/config",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/config",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationEmail\": \"{{notification_email}}\",\n  \"watchedRepo\": \"{{watched_repo}}\",\n  \"watchedLabel\": \"{{watched_label}}\",\n  \"issueLimit\": {{issue_limit}},\n  \"notifyStartTime\": \"{{notify_start_time}}\",\n  \"notifyEndTime\": \"{{notify_end_time}}\",\n  \"notifyTimezone\": \"{{notify_timezone}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "PUT /api/config — set GitHub token",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/config",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"githubToken\": \"ghp_YOUR_TOKEN_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "GET /api/config/status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/config/status"
          }
        },
        {
          "name": "POST /api/config/start",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/config/start"
          }
        },
        {
          "name": "POST /api/config/stop",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/config/stop"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "GET /api/notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notifications?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "SENT", "disabled": true },
                { "key": "includeDeleted", "value": "false", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /api/notifications/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/notifications/{{notification_id}}"
          }
        },
        {
          "name": "POST /api/notifications/track",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notifications/track",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issueNumber\": {{issue_number}}\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "DELETE /api/notifications/:id (soft)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/notifications/{{notification_id}}"
          }
        },
        {
          "name": "POST /api/notifications/:id/restore",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notifications/{{notification_id}}/restore"
          }
        },
        {
          "name": "DELETE /api/notifications/:id/hard",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/notifications/{{notification_id}}/hard"
          }
        }
      ]
    }
  ]
}
