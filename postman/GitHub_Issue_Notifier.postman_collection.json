{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "GitHub Issue Notifier",
    "description": "Complete API collection for the GitHub Issue Notifier backend. Monitors a GitHub repo for new issues matching a label and sends email notifications.\n\n**Setup:**\n1. Import the companion environment file `GitHub_Issue_Notifier.postman_environment.json`\n2. Select the environment in Postman\n3. Set `base_url` to your server (default: `http://localhost:3001`)\n4. Use **Config → Update Config** to configure your repo, label, email, and optional notify window\n5. Use **Config → Start Service** to begin monitoring\n\n**Notify Window:**\nOptional time filter. Set `notifyStartTime` + `notifyEndTime` (HH:MM, 24h) and `notifyTimezone` (IANA). Events outside the window are permanently skipped — not held for later. Overnight windows are supported (e.g. 22:00–06:00). Leave both times empty to disable the filter.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://expensify-backend-dusky-summit-570.fly.dev",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Uptime and readiness checks. Not rate-limited.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Basic liveness check. Returns server uptime."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"ok\",\n  \"uptime\": 123.456\n}"
            }
          ]
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/ready",
              "host": ["{{base_url}}"],
              "path": ["health", "ready"]
            },
            "description": "Verifies database connectivity. Returns 503 if the DB is unreachable."
          },
          "response": [
            {
              "name": "200 Ready",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"ready\",\n  \"db\": \"connected\"\n}"
            },
            {
              "name": "503 Not Ready",
              "status": "Service Unavailable",
              "code": 503,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"not ready\",\n  \"db\": \"disconnected\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Config",
      "description": "Manage application configuration and control the notification service.\n\nRate limit: 200 requests / 15 minutes.",
      "item": [
        {
          "name": "Get Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('config + hasGithubToken present', () => {",
                  "  pm.expect(body).to.have.property('config');",
                  "  pm.expect(body).to.have.property('hasGithubToken');",
                  "  pm.expect(body.hasGithubToken).to.be.a('boolean');",
                  "});",
                  "pm.test('config schema', () => {",
                  "  const c = body.config;",
                  "  pm.expect(c.notificationEmail).to.be.a('string');",
                  "  pm.expect(c.watchedRepo).to.be.a('string');",
                  "  pm.expect(c.watchedLabel).to.be.a('string');",
                  "  pm.expect(c.issueLimit).to.be.a('number');",
                  "  pm.expect(c.isRunning).to.be.a('boolean');",
                  "  pm.expect(c.notifyStartTime).to.be.a('string');",
                  "  pm.expect(c.notifyEndTime).to.be.a('string');",
                  "  pm.expect(c.notifyTimezone).to.be.a('string');",
                  "  pm.expect(c.myGithubUsername).to.be.a('string');",
                  "  pm.expect(c.autoProposal).to.be.a('boolean');",
                  "  pm.expect(c.dailyResetDate).to.be.a('string');",
                  "  pm.expect(c).to.have.property('lastRestartAt');",
                  "  pm.expect(c.updatedAt, 'updatedAt is ISO datetime').to.match(/^\\d{4}-\\d{2}-\\d{2}T/);",
                  "});",
                  "pm.test('githubToken/lastEtag never exposed', () => {",
                  "  pm.expect(body.config).to.not.have.property('githubToken');",
                  "  pm.expect(body.config).to.not.have.property('lastEtag');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config",
              "host": ["{{base_url}}"],
              "path": ["api", "config"]
            },
            "description": "Returns current configuration. GitHub token is never exposed — only a `hasGithubToken` boolean is returned."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"config\": {\n    \"id\": \"singleton\",\n    \"notificationEmail\": \"you@example.com\",\n    \"watchedRepo\": \"Expensify/App\",\n    \"watchedLabel\": \"Help Wanted\",\n    \"issueLimit\": 4,\n    \"pollIntervalSeconds\": 60,\n    \"dailySelectedCount\": 2,\n    \"dailyResetDate\": \"2026-06-28\",\n    \"isRunning\": true,\n    \"notifyStartTime\": \"09:00\",\n    \"notifyEndTime\": \"18:00\",\n    \"notifyTimezone\": \"Asia/Kolkata\",\n    \"myGithubUsername\": \"octocat\",\n    \"autoProposal\": false,\n    \"lastRestartAt\": \"2026-06-28T03:00:00.000Z\",\n    \"updatedAt\": \"2026-06-28T09:00:00.000Z\"\n  },\n  \"hasGithubToken\": true\n}"
            }
          ]
        },
        {
          "name": "Update Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns updated config schema', () => {",
                  "  const c = body.config;",
                  "  pm.expect(c).to.be.an('object');",
                  "  pm.expect(c.watchedRepo).to.be.a('string');",
                  "  pm.expect(c.watchedLabel).to.be.a('string');",
                  "  pm.expect(c.issueLimit).to.be.a('number');",
                  "  pm.expect(c.notifyStartTime).to.be.a('string');",
                  "  pm.expect(c.notifyEndTime).to.be.a('string');",
                  "  pm.expect(c.notifyTimezone).to.be.a('string');",
                  "  pm.expect(c.myGithubUsername).to.be.a('string');",
                  "  pm.expect(c.autoProposal).to.be.a('boolean');",
                  "  pm.expect(c.dailyResetDate).to.be.a('string');",
                  "  pm.expect(c).to.have.property('lastRestartAt');",
                  "  pm.expect(c.updatedAt, 'updatedAt is ISO datetime').to.match(/^\\d{4}-\\d{2}-\\d{2}T/);",
                  "});",
                  "pm.test('githubToken/lastEtag never exposed', () => {",
                  "  pm.expect(body.config).to.not.have.property('githubToken');",
                  "  pm.expect(body.config).to.not.have.property('lastEtag');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationEmail\": \"{{notification_email}}\",\n  \"watchedRepo\": \"{{watched_repo}}\",\n  \"watchedLabel\": \"{{watched_label}}\",\n  \"issueLimit\": 4,\n  \"githubToken\": \"{{github_token}}\",\n  \"notifyStartTime\": \"{{notify_start_time}}\",\n  \"notifyEndTime\": \"{{notify_end_time}}\",\n  \"notifyTimezone\": \"{{notify_timezone}}\",\n  \"myGithubUsername\": \"{{my_github_username}}\",\n  \"autoProposal\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/config",
              "host": ["{{base_url}}"],
              "path": ["api", "config"]
            },
            "description": "Partial update — only send fields you want to change. All fields are optional.\n\n**Field rules:**\n- `notificationEmail` — valid email\n- `watchedRepo` — must be `owner/repo` format\n- `watchedLabel` — non-empty string\n- `issueLimit` — integer 1–100\n- `githubToken` — non-empty string or `null` (set to null to remove)\n- `notifyStartTime` — `HH:MM` (00:00–23:59) or `\"\"` to clear\n- `notifyEndTime` — `HH:MM` (00:00–23:59) or `\"\"` to clear\n- `notifyTimezone` — valid IANA timezone (e.g. `UTC`, `Asia/Kolkata`, `America/New_York`)\n- `myGithubUsername` — your GitHub username, used to attribute auto-generated proposals (string, may be empty)\n- `autoProposal` — boolean; when `true`, the service automatically drafts and posts a proposal for newly selected issues\n\n**Side effects:**\n- Changing `watchedRepo` resets `lastEtag`, `dailySelectedCount`, and `dailyResetDate`\n- Setting `notifyStartTime` or `notifyEndTime` to `\"\"` disables the window filter entirely\n\n**Notify window behaviour:**\nWhen both start and end are set, GitHub events that arrive outside the window are permanently consumed (ETag saved first) and no notification record is created. Events are skipped — not held for later."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"config\": {\n    \"id\": \"singleton\",\n    \"notificationEmail\": \"you@example.com\",\n    \"watchedRepo\": \"Expensify/App\",\n    \"watchedLabel\": \"Help Wanted\",\n    \"issueLimit\": 4,\n    \"pollIntervalSeconds\": 60,\n    \"dailySelectedCount\": 2,\n    \"dailyResetDate\": \"2026-06-28\",\n    \"isRunning\": true,\n    \"notifyStartTime\": \"09:00\",\n    \"notifyEndTime\": \"18:00\",\n    \"notifyTimezone\": \"Asia/Kolkata\",\n    \"myGithubUsername\": \"octocat\",\n    \"autoProposal\": false,\n    \"lastRestartAt\": \"2026-06-28T03:00:00.000Z\",\n    \"updatedAt\": \"2026-06-28T09:15:00.000Z\"\n  },\n  \"hasGithubToken\": true\n}"
            },
            {
              "name": "400 Validation Error",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Validation error\",\n  \"details\": {\n    \"notifyTimezone\": \"Must be a valid IANA timezone (e.g. UTC, Asia/Kolkata, America/New_York)\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Notify Window",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notifyStartTime\": \"{{notify_start_time}}\",\n  \"notifyEndTime\": \"{{notify_end_time}}\",\n  \"notifyTimezone\": \"{{notify_timezone}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/config",
              "host": ["{{base_url}}"],
              "path": ["api", "config"]
            },
            "description": "Sets only the notify window fields without touching other config.\n\nUse `{{notify_start_time}}` / `{{notify_end_time}}` from the environment (default `09:00` / `18:00`).\n\n**Overnight window example:** set `notifyStartTime` = `22:00` and `notifyEndTime` = `06:00` — the system handles the wrap-around automatically.\n\nAfter saving, check `GET /api/config/status` → `isInNotifyWindow` to confirm the current time falls inside the window."
          },
          "response": [
            {
              "name": "200 OK — Window set",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"config\": {\n    \"id\": \"singleton\",\n    \"notifyStartTime\": \"09:00\",\n    \"notifyEndTime\": \"18:00\",\n    \"notifyTimezone\": \"Asia/Kolkata\",\n    \"isRunning\": true,\n    \"updatedAt\": \"2026-06-28T03:30:00.000Z\"\n  },\n  \"hasGithubToken\": true\n}"
            },
            {
              "name": "400 Invalid timezone",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Validation error\",\n  \"details\": {\n    \"notifyTimezone\": \"Must be a valid IANA timezone (e.g. UTC, Asia/Kolkata, America/New_York)\"\n  }\n}"
            },
            {
              "name": "400 Invalid time format",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Validation error\",\n  \"details\": {\n    \"notifyStartTime\": \"Must be HH:MM (00:00\\u201323:59) or empty string\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Clear Notify Window",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notifyStartTime\": \"\",\n  \"notifyEndTime\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/config",
              "host": ["{{base_url}}"],
              "path": ["api", "config"]
            },
            "description": "Disables the notify window filter by setting both times to empty strings. After this, the service will notify at any time of day."
          },
          "response": [
            {
              "name": "200 OK — Window cleared",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"config\": {\n    \"id\": \"singleton\",\n    \"notifyStartTime\": \"\",\n    \"notifyEndTime\": \"\",\n    \"notifyTimezone\": \"UTC\",\n    \"isRunning\": true,\n    \"updatedAt\": \"2026-06-28T09:00:00.000Z\"\n  },\n  \"hasGithubToken\": true\n}"
            }
          ]
        },
        {
          "name": "Get Service Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status schema', () => {",
                  "  pm.expect(body.isRunning).to.be.a('boolean');",
                  "  pm.expect(body.watchedRepo).to.be.a('string');",
                  "  pm.expect(body.watchedLabel).to.be.a('string');",
                  "  pm.expect(body.issueLimit).to.be.a('number');",
                  "  pm.expect(body.dailySelectedCount).to.be.a('number');",
                  "  pm.expect(body.isNewDay).to.be.a('boolean');",
                  "  pm.expect(body.pollIntervalSeconds).to.be.a('number');",
                  "  pm.expect(body.hasGithubToken).to.be.a('boolean');",
                  "  pm.expect(body.isInNotifyWindow).to.be.a('boolean');",
                  "  pm.expect(body.myGithubUsername).to.be.a('string');",
                  "  pm.expect(body.autoProposal).to.be.a('boolean');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config/status",
              "host": ["{{base_url}}"],
              "path": ["api", "config", "status"]
            },
            "description": "Quick snapshot of the service state.\n\n- `isNewDay` — `true` when today's date differs from `dailyResetDate` (counter hasn't reset yet this session)\n- `isInNotifyWindow` — `true` when the current time (in `notifyTimezone`) falls inside the configured window, or when no window is set (both times are empty)"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"isRunning\": true,\n  \"watchedRepo\": \"Expensify/App\",\n  \"watchedLabel\": \"Help Wanted\",\n  \"issueLimit\": 4,\n  \"notificationEmail\": \"you@example.com\",\n  \"dailySelectedCount\": 2,\n  \"isNewDay\": false,\n  \"pollIntervalSeconds\": 60,\n  \"hasGithubToken\": true,\n  \"notifyStartTime\": \"09:00\",\n  \"notifyEndTime\": \"18:00\",\n  \"notifyTimezone\": \"Asia/Kolkata\",\n  \"isInNotifyWindow\": true,\n  \"myGithubUsername\": \"octocat\",\n  \"autoProposal\": false,\n  \"lastRestartAt\": \"2026-06-28T03:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Start Service",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config/start",
              "host": ["{{base_url}}"],
              "path": ["api", "config", "start"]
            },
            "description": "Enables the notification service (`isRunning = true`). Requires `notificationEmail` to be set first — returns 400 otherwise. The poller and email sender will begin processing on the next scheduler tick."
          },
          "response": [
            {
              "name": "200 Started",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"running\",\n  \"message\": \"Notification service started\"\n}"
            },
            {
              "name": "400 No Email Set",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"notificationEmail must be set before starting\"\n}"
            }
          ]
        },
        {
          "name": "Stop Service",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config/stop",
              "host": ["{{base_url}}"],
              "path": ["api", "config", "stop"]
            },
            "description": "Disables the notification service (`isRunning = false`). In-flight emails are not cancelled. Poller stops checking GitHub on the next cycle."
          },
          "response": [
            {
              "name": "200 Stopped",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"stopped\",\n  \"message\": \"Notification service stopped\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Notifications",
      "description": "Manage notification records (one record per selected GitHub issue).\n\nRate limit: 200 requests / 15 minutes.",
      "item": [
        {
          "name": "List Notifications",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Auto-capture first record ID for use in other requests",
                  "const body = pm.response.json();",
                  "if (body.data && body.data.length > 0) {",
                  "  pm.environment.set('notification_id', body.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (≥1, default 1)" },
                { "key": "limit", "value": "20", "description": "Records per page (1–100, default 20)" },
                { "key": "status", "value": "PENDING", "description": "Filter by status: PENDING | SENT | FAILED", "disabled": true },
                { "key": "includeDeleted", "value": "true", "description": "Include soft-deleted records (default false)", "disabled": true }
              ]
            },
            "description": "Returns paginated notification records. Soft-deleted records are excluded by default.\n\nA test script automatically captures the first record's `id` into `{{notification_id}}`."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": [\n    {\n      \"id\": \"cma1b2c3d4e5f6g7h8i9j0\",\n      \"githubIssueNumber\": 42,\n      \"title\": \"Fix login flow\",\n      \"url\": \"https://github.com/Expensify/App/issues/42\",\n      \"repoFullName\": \"Expensify/App\",\n      \"matchedLabel\": \"Help Wanted\",\n      \"status\": \"SENT\",\n      \"attempts\": 1,\n      \"lastAttemptAt\": \"2025-02-15T10:30:00.000Z\",\n      \"notifiedAt\": \"2025-02-15T10:30:00.000Z\",\n      \"hasPendingUpdate\": false,\n      \"updateEmailCount\": 0,\n      \"lastUpdateEmailAt\": null,\n      \"deletedAt\": null,\n      \"createdAt\": \"2025-02-15T10:00:00.000Z\",\n      \"updatedAt\": \"2025-02-15T10:30:00.000Z\"\n    }\n  ],\n  \"pagination\": {\n    \"page\": 1,\n    \"limit\": 20,\n    \"total\": 1,\n    \"pages\": 1\n  }\n}"
            }
          ]
        },
        {
          "name": "List — PENDING only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications?status=PENDING",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "status", "value": "PENDING" }
              ]
            },
            "description": "Convenience request to see only records awaiting email delivery."
          },
          "response": []
        },
        {
          "name": "List — SENT only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications?status=SENT",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "status", "value": "SENT" }
              ]
            },
            "description": "Convenience request to see only successfully delivered notifications."
          },
          "response": []
        },
        {
          "name": "List — Include Deleted",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications?includeDeleted=true",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "includeDeleted", "value": "true" }
              ]
            },
            "description": "Shows all records including soft-deleted ones."
          },
          "response": []
        },
        {
          "name": "Get Notification",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications/{{notification_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "{{notification_id}}"]
            },
            "description": "Fetch a single notification record by its CUID. Set `{{notification_id}}` in the environment or run **List Notifications** first (the test script auto-captures the ID)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
